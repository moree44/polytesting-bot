# Required secrets
PK=
WALLET_ADDRESS=
POLY_PROXY=
CLOB_FUNDER=

# Core
CLOB_SIGNATURE_TYPE=2
DRY_RUN=1
WEB_HOST=127.0.0.1
WEB_PORT=8787

# Trading guards
MAX_ENTRY_CENT=99
MIN_MARKET_TIME_LEFT=45
ENTRY_SLIPPAGE_BPS=50
EXIT_SLIPPAGE_BPS=80
MIN_ORDER_SHARES=0.01
MIN_ORDER_USD=0.01
STRICT_EXECUTION=1
BUY_CMD_GUARD_SEC=1.2
MARKET_BUY_ORDER_TYPE=FAK

# Position sync
POSITION_SYNC_GRACE=8
POSITION_DUST_SHARES=0.005
POSITION_DUST_USD=0.02

# Chart
CENT_DECIMALS=2
CHART_SAMPLE_SEC=1.0
CHART_MAX_CANDLES_1M=360

# PTB & switching
GTC_FALLBACK_TIMEOUT=0
TERM_STATUS_INTERVAL=10
NEXT_PREFETCH_SEC=120
SWITCH_MIN_REMAINING_SEC=10
PTB_MAX_DRIFT_SEC=1
PTB_WEB_FALLBACK=0
PTB_WEB_RETRY_SEC=30
UNCERTAIN_BUY_VERIFY_SEC=18
UNCERTAIN_BUY_POLL_SEC=1.0

# Probability scoring
PROB_VOL_WINDOW_SEC=240
PROB_DEFAULT_VOL_ANNUAL=0.75
PROB_W_MARKET=0.50
PROB_W_PTB=0.40
PROB_W_MICRO=0.10
PROB_SCORE_DRIFT_SEC=15

# Binance HTTP
BINANCE_FORCE_IPV4=1
BINANCE_HTTP_TIMEOUT=10
BINANCE_HTTP_PROXY=
BINANCE_HTTPS_PROXY=
BINANCE_API_BASES=https://api.binance.com,https://api1.binance.com,https://api2.binance.com,https://api3.binance.com,https://data-api.binance.vision

# Web auth (optional)
WEB_USER=
WEB_PASS=
WEB_AUTH_TTL_SEC=3600

# User WS
USER_WS_ENABLED=1
